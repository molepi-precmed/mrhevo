    model_path=model_path,
    num_warmup=500,
    num_samples=1000,
    num_chains=4)
options(warn=2)

## get maximum likelihood estimate of theta from posterior density
theta.samples <- hevo.fit$posterior$theta
prior.theta <- dnorm(theta.samples, mean=0, sd=priorsd_theta)
