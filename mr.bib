  author = {Borges, Maria Carolina and Barros, Aluísio J. D. and Ferreira, Diana L. Santos and Casas, Juan Pablo and Horta, Bernardo Lessa and Kivimaki, Mika and Kumari, Meena and Menon, Usha and Gaunt, Tom R. and {Ben-Shlomo}, Yoav and Freitas, Deise F. and Oliveira, Isabel O. and {Gentry-Maharaj}, Aleksandra and Fourkala, Evangelia and Lawlor, Debbie A. and Hingorani, Aroon D.},
  year = 2017,
  month = dec,
  journal = {Circ Cardiovasc Genet},
  volume = {10},
  number = {6},
