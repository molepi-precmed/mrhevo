@article{sanderson_examination_2019,
  title = {An Examination of Multivariable {{Mendelian}} Randomization in the Single-Sample and Two-Sample Summary Data Settings},
  author = {Sanderson, Eleanor and Davey Smith, George and Windmeijer, Frank and Bowden, Jack},
  year = 2019,
