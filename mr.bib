  author = {Chun, Sung and Casparino, Alexandra and Patsopoulos, Nikolaos A. and {Croteau-Chonka}, Damien C. and Raby, Benjamin A. and De Jager, Philip L. and Sunyaev, Shamil R. and Cotsapas, Chris},
