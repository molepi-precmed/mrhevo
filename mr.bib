@article{boehm_statistical_2022,
  title = {Statistical Methods for {{Mendelian}} Randomization in Genome-Wide Association Studies: {{A}} Review},
  shorttitle = {Statistical Methods for {{Mendelian}} Randomization in Genome-Wide Association Studies},
  author = {Boehm, Frederick J. and Zhou, Xiang},
