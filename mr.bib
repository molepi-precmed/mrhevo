  author = {Skrivankova, Veronika W. and Richmond, Rebecca C. and Woolf, Benjamin A. R. and Davies, Neil M. and Swanson, Sonja A. and VanderWeele, Tyler J. and Timpson, Nicholas J. and Higgins, Julian P. T. and Dimou, Niki and Langenberg, Claudia and Loder, Elizabeth W. and Golub, Robert M. and Egger, Matthias and Davey Smith, George and Richards, J. Brent},
