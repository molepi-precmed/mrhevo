  keywords = {Autoimmune Diseases,Gene Expression,Gene Regulatory Networks,Genetic Predisposition to Disease,Genome-Wide Association Study,Humans,Immunity,Polymorphism,Polymorphism Single Nucleotide,Quantitative Trait Loci,Single Nucleotide},
